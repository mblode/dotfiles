{
  "extends": "stylelint-config-standard",
  "rules": {
    "indentation": 4,
    "at-rule-no-unknown": [ true, {
      "ignoreAtRules": [
        "extends",
        "ignores",
        "content",
        "mixin",
        "include",
        "each",
        "if",
        "for",
        "else",
        "return",
        "function",
      ]
    }],
  }
}