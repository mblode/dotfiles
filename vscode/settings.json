{
    "editor.fontSize": 14,
    "editor.fontLigatures": true,
    "editor.fontFamily":
        "Operator Mono Lig, Menlo, Monaco, 'Courier New', monospace",
    "terminal.integrated.cursorStyle": "line",
    "workbench.startupEditor": "newUntitledFile",
    "emmet.syntaxProfiles": {
        "javascript": "javascriptreact"
    },
    "workbench.iconTheme": "material-icon-theme",
    "emmet.triggerExpansionOnTab": true,
    "terminal.integrated.fontSize": 14,
    "prettier.tabWidth": 4,
    "prettier.stylelintIntegration": true,
    "editor.trimAutoWhitespace": true,
    "files.trimTrailingWhitespace": true,
    "git.enableSmartCommit": true,
    "explorer.openEditors.visible": 0,
    "editor.minimap.renderCharacters": false,
    "editor.minimap.enabled": false,
    "editor.wordWrap": "on",
    "workbench.colorTheme": "One Dark Italic",
    "material-icon-theme.showUpdateMessage": false,
    "git.autofetch": true,
    "extensions.ignoreRecommendations": true,
    "files.associations": {
        "*.html": "twig",
        "*.js": "javascriptreact"
    },
    "emmet.includeLanguages": {
        "twig": "html",
        "mjml": "html",
        "vue": "html",
        "javascript": "javascriptreact"
    },
    "bracketPairColorizer.forceIterationColorCycle": true,
    "javascript.updateImportsOnFileMove.enabled": "always",
    "window.zoomLevel": 0,
    "C_Cpp.clang_format_fallbackStyle": "WebKit",
    "code-runner.runInTerminal": true,
    "code-runner.executorMap": {
        "c": "cd $dir && gcc -Wall $fileName -o $fileNameWithoutExt && $dir$fileNameWithoutExt",
    },
    "files.autoSave": "onFocusChange",
    "editor.autoClosingBrackets": "always",
    "editor.minimap.maxColumn": 80,
    "html.format.wrapLineLength": 80,
    "files.insertFinalNewline": true,
    "workbench.editor.tabSizing": "shrink",
    "html.format.endWithNewline": true,
    "html.format.indentInnerHtml": true,
    "editor.minimap.showSlider": "always",
    "cSpell.language": "en,en-GB",
    "cSpell.userWords": [
        "blode"
    ],
    "prettier.singleQuote": true,
    "css.lint.unknownAtRules": "ignore",
    "scss.lint.unknownProperties": "ignore",
    "scss.lint.emptyRules": "ignore",
    "explorer.confirmDragAndDrop": false,
    "prettier.useTabs": true,
    "twig-language-2.wrap": 80,
    "typescript.updateImportsOnFileMove.enabled": "always",
    "prettier.printWidth": 200,
    "[markdown]": {
        "editor.fontSize": 16,
        "editor.formatOnSave": true,
        "editor.wordWrap": "wordWrapColumn",
        "editor.acceptSuggestionOnEnter": "off",
        "editor.wordWrapColumn": 66
    }
}
