# zmodload zsh/zprof

# Prevent inherited nested-session marker from breaking Claude CLI launches.
# This can leak in from parent tools that embed terminals.
unset CLAUDECODE

# Path
export NOTES="$HOME/Library/Mobile Documents/27N4MQEA55~pro~writer/Documents"
export OBSIDIAN="$HOME/Library/Mobile Documents/iCloud~md~obsidian/Documents/second-brain"
export DATA_LAKE="$HOME/data-lake"
export EDITOR="zed"
export TERM=xterm-256color

# Portless: bind on 1355 instead of 443 so Docker (ltd-proxy) can own 443
export PORTLESS_PORT=1355

# Starship
eval "$(starship init zsh)"

# NVM — lazy loaded to keep shell startup fast. nvm/node/npm/npx load on first
# use; node version auto-switches when entering a dir tree with .nvmrc/.node-version.
export NVM_DIR="$([ -z "${XDG_CONFIG_HOME-}" ] && printf %s "${HOME}/.nvm" || printf %s "${XDG_CONFIG_HOME}/nvm")"

_nvm_load() {
  unset -f nvm node npm npx _nvm_load 2>/dev/null
  [ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"
  [ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"
  # token only needed once node tooling is in use (was eager at startup)
  export NPM_TOKEN="$(grep -E '^//registry\.npmjs\.org/:_authToken=' ~/.npmrc 2>/dev/null | tail -n1 | cut -d= -f2-)"
}
for _cmd in nvm node npm npx; do
  eval "${_cmd}() { _nvm_load; ${_cmd} \"\$@\"; }"
done
unset _cmd

# Original auto-switch logic, unchanged — only invoked after nvm is loaded.
load-nvmrc() {
  local nvmrc_path="$(nvm_find_nvmrc)"

  if [ -n "$nvmrc_path" ]; then
    local nvmrc_node_version=$(nvm version "$(cat "${nvmrc_path}")")

    if [ "$nvmrc_node_version" = "N/A" ]; then
      nvm install
    elif [ "$nvmrc_node_version" != "$(nvm version)" ]; then
      nvm use
    fi
  elif [ -n "$(PWD=$OLDPWD nvm_find_nvmrc)" ] && [ "$(nvm version)" != "$(nvm version default)" ]; then
    echo "Reverting to nvm default version"
    nvm use default
  fi
}

# Lightweight upward search so we only wake nvm inside node projects.
_nvm_find_rc() {
  local dir="$PWD"
  while [[ -n "$dir" ]]; do
    [[ -e "$dir/.nvmrc" || -e "$dir/.node-version" ]] && return 0
    dir="${dir%/*}"
  done
  return 1
}
autoload -U add-zsh-hook
_nvm_auto_use() {
  if _nvm_find_rc; then
    command -v nvm_find_nvmrc >/dev/null 2>&1 || _nvm_load
    load-nvmrc
  fi
}
add-zsh-hook chpwd _nvm_auto_use
_nvm_auto_use   # honor the directory the shell starts in


# zsh-users/zsh-completions — must be on fpath BEFORE compinit runs (below)
fpath+=($HOME/.zsh/zsh-completions/src $fpath)

# Completions: dedupe fpath (stops compinit rebuilding the dump every launch),
# then init once with a once-a-day security check. compinit must run before
# fzf-tab is sourced.
typeset -U fpath
autoload -Uz compinit
if [[ -n ${HOME}/.zcompdump(#qN.mh+24) ]]; then
  compinit -u           # dump older than 24h: full rebuild + security check
else
  compinit -C           # fresh (or absent) dump: skip the slow scan
fi

# Aloxaf/fzf-tab — load after compinit, before widget-wrapping plugins
source $HOME/.zsh/fzf-tab/fzf-tab.plugin.zsh

# zsh-users/zsh-autosuggestions
source $HOME/.zsh/zsh-autosuggestions/zsh-autosuggestions.zsh

# zsh-users/zsh-syntax-highlighting
source $HOME/.zsh/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh

# zsh-users/zsh-history-substring-search
source $HOME/.zsh/zsh-history-substring-search/zsh-history-substring-search.zsh

# Stash your environment variables in ~/.localrc. This means they'll stay out
# of your main dotfiles repository (which may be public, like this one), but
# you'll have access to them in your scripts.
if [[ -a ~/.localrc ]]
then
  source ~/.localrc
fi

# Split config (options, aliases) lives in ~/.config/zsh, deployed by chezmoi.
for file in ~/.config/zsh/*.zsh(N); do
  source "$file"
done

bindkey '^S' history-incremental-search-forward  # Perform forward search in command line history
bindkey '^P' history-search-backward             # Go back/search in history (autocomplete)
bindkey '^N' history-search-forward              # Go forward/search in history (autocomplete)

# Better history
autoload -U up-line-or-beginning-search
autoload -U down-line-or-beginning-search
zle -N up-line-or-beginning-search
zle -N down-line-or-beginning-search
bindkey "^[[A" up-line-or-beginning-search # Up
bindkey "^[[B" down-line-or-beginning-search # Down

# bind UP and DOWN arrow keys (compatibility fallback)
bindkey '^[[A' history-substring-search-up
bindkey '^[[B' history-substring-search-down

# FZF
[ -f ~/.fzf.zsh ] && source ~/.fzf.zsh
export FZF_DEFAULT_COMMAND='rg --files --no-ignore-vcs --hidden'
export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"
export FZF_DEFAULT_OPTS="--height 40% --layout=reverse --border"

# Zoxide
eval "$(zoxide init zsh)"

# Do not track
export DO_NOT_TRACK=1

# Autoship

# FZF Tabs
# disable sort when completing `git checkout`
zstyle ':completion:*:git-checkout:*' sort false
# set descriptions format to enable group support
zstyle ':completion:*:descriptions' format '[%d]'
# set list-colors to enable filename colorizing
zstyle ':completion:*' list-colors ${(s.:.)LS_COLORS}
# preview directory's content with exa when completing cd
zstyle ':fzf-tab:complete:cd:*' fzf-preview 'exa -5 --color=always $realpath'
# switch group using `,` and `.`
zstyle ':fzf-tab:*' switch-group ',' '.'

export PATH="$HOME/bin:$PATH"

eval "$(atuin init zsh)"

. "$HOME/.atuin/bin/env"
export PATH="$HOME/Library/Python/3.9/bin:$PATH"

# NPM_TOKEN is set lazily in _nvm_load (only when node tooling is first used)
export PATH="$HOME/.hermes/node/bin:$PATH"

# tabtab source for packages
# uninstall by removing these lines
[[ -f ~/.config/tabtab/__tabtab.zsh ]] && . ~/.config/tabtab/__tabtab.zsh || true
export PATH="$HOME/.local/bin:$PATH"

# bun completions
[ -s "$HOME/.bun/_bun" ] && source "$HOME/.bun/_bun"

# bun
export BUN_INSTALL="$HOME/.bun"
export PATH="$BUN_INSTALL/bin:$PATH"

# Resend CLI
export PATH="$HOME/.resend/bin:$PATH"

# Add a skill: symlink from source repo → .agents/skills → Claude + Codex
# Usage: skill-add ~/Code/mblode/style-capture/skills/style-capture
skill-add() {
  local src="${1:A}"
  local name="$(basename $src)"
  ln -sfn "$src" ~/.agents/skills/$name
  ln -sfn ../../.agents/skills/$name ~/.claude/skills/$name
  ln -sfn ../../.agents/skills/$name ~/.codex/skills/$name
  echo "Linked $name → Claude + Codex"
}

