#!/bin/bash
#
# linear-worktree — Create a sibling git worktree for a Linear issue.
#
# Usage:
#   linear-worktree <issue-id-or-url-or-text>
#   linear-worktree TIG-234 personality stuff
#   echo "ABC-58 Add dark mode" | linear-worktree
#
# Env:
#   LINEAR_WORKTREE_REPO  Fallback repo path when cwd isn't a git repo.
#   LINEAR_API_KEY        Linear personal API key; enables title/description/url lookup.
#   NO_COLOR              Disable colored output.

set -euo pipefail

if [ -t 2 ] && [ -z "${NO_COLOR:-}" ]; then
  C_BOLD=$'\033[1m'; C_DIM=$'\033[2m'
  C_CYAN=$'\033[36m'; C_RED=$'\033[31m'
  C_RESET=$'\033[0m'
else
  C_BOLD=''; C_DIM=''; C_CYAN=''; C_RED=''; C_RESET=''
fi

SPIN_FRAMES='⠋⠙⠹⠸⠼⠴⠦⠧⠇⠏'
SPIN_PID=""

spin_start() {
  local msg="$1"
  [ -t 2 ] || return 0
  (
    trap 'exit 0' TERM
    i=0
    while :; do
      f="${SPIN_FRAMES:$((i % ${#SPIN_FRAMES})):1}"
      printf '\r\033[K%s%s%s %s' "$C_CYAN" "$f" "$C_RESET" "$msg" >&2
      sleep 0.08
      i=$((i + 1))
    done
  ) & SPIN_PID=$!
  disown "$SPIN_PID" 2>/dev/null || true
}

spin_stop() {
  if [ -n "$SPIN_PID" ]; then
    kill "$SPIN_PID" 2>/dev/null || true
    wait "$SPIN_PID" 2>/dev/null || true
    SPIN_PID=""
    printf '\r\033[K' >&2
  fi
}

fail() { spin_stop; printf '%s✗%s %s\n' "$C_RED" "$C_RESET" "$1" >&2; exit 1; }

trap 'spin_stop' EXIT INT TERM
trap 'rc=$?; spin_stop; printf "%s✗%s setup failed (exit %s)\n" "$C_RED" "$C_RESET" "$rc" >&2; exit $rc' ERR

if [ "$#" -gt 0 ]; then
  INPUT="$*"
elif [ ! -t 0 ]; then
  IFS= read -r INPUT || true
else
  echo "usage: linear-worktree <issue-id|url|copy-as-prompt-text>" >&2
  exit 2
fi
INPUT="${INPUT#"${INPUT%%[![:space:]]*}"}"
INPUT="${INPUT%"${INPUT##*[![:space:]]}"}"
[ -n "${INPUT:-}" ] || fail "empty input"

slugify() {
  local s="$1"
  s="$(printf '%s' "$s" | tr '[:upper:]' '[:lower:]' | tr -d "'\`")"
  s="$(printf '%s' "$s" | sed -E 's/[^a-z0-9]+/-/g; s/^-+//; s/-+$//')"
  if [ "${#s}" -gt 60 ]; then
    s="${s:0:60}"
    s="${s%-*}"
  fi
  printf '%s' "$s"
}

ID_RE='[A-Za-z][A-Za-z0-9_]*-[0-9]+'
ISSUE_ID=""
SLUG=""

if [[ "$INPUT" =~ ^https?://linear\.app/[^/]+/issue/(${ID_RE})/?(.*)$ ]]; then
  ISSUE_ID="${BASH_REMATCH[1]}"
  tail="${BASH_REMATCH[2]}"
  SLUG="$(slugify "${tail%%[?#]*}")"
elif [[ "$INPUT" =~ ^(${ID_RE})([[:space:]]+(.*))?$ ]]; then
  ISSUE_ID="${BASH_REMATCH[1]}"
  SLUG="$(slugify "${BASH_REMATCH[3]:-}")"
else
  fail "could not parse issue ID from: $INPUT"
fi

ISSUE_ID="$(printf '%s' "$ISSUE_ID" | tr '[:upper:]' '[:lower:]')"
DISPLAY_ID="$(printf '%s' "$ISSUE_ID" | tr '[:lower:]' '[:upper:]')"

if REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null)"; then
  :
elif [ -n "${LINEAR_WORKTREE_REPO:-}" ]; then
  REPO_ROOT="$(git -C "$LINEAR_WORKTREE_REPO" rev-parse --show-toplevel)"
else
  fail "not in a git repo (set LINEAR_WORKTREE_REPO to a repo path)"
fi
REPO_NAME="$(basename "$REPO_ROOT")"
REPOS_BASE="$(dirname "$REPO_ROOT")"
WORKTREE_PATH="$REPOS_BASE/$REPO_NAME-$ISSUE_ID"

spin_start "Setting up $DISPLAY_ID"

LINEAR_TITLE=""
LINEAR_DESCRIPTION=""
LINEAR_URL=""
if [ -n "${LINEAR_API_KEY:-}" ] && command -v curl >/dev/null 2>&1 && command -v jq >/dev/null 2>&1; then
  payload="$(jq -cn --arg id "$DISPLAY_ID" '{query:"query($id:String!){issue(id:$id){title description url}}",variables:{id:$id}}')"
  response="$(curl -fsS -X POST https://api.linear.app/graphql \
    -H "Authorization: $LINEAR_API_KEY" \
    -H "Content-Type: application/json" \
    --data-binary "$payload" 2>/dev/null || true)"
  if [ -n "$response" ] && [ "$(printf '%s' "$response" | jq -r '.data.issue // empty' 2>/dev/null)" != "" ]; then
    LINEAR_TITLE="$(printf '%s' "$response"       | jq -r '.data.issue.title       // empty')"
    LINEAR_DESCRIPTION="$(printf '%s' "$response" | jq -r '.data.issue.description // empty')"
    LINEAR_URL="$(printf '%s' "$response"         | jq -r '.data.issue.url         // empty')"
    if [ -z "$SLUG" ] && [ -n "$LINEAR_TITLE" ]; then
      SLUG="$(slugify "$LINEAR_TITLE")"
    fi
  fi
fi

BRANCH="$ISSUE_ID${SLUG:+-$SLUG}"
git -C "$REPO_ROOT" check-ref-format --branch "$BRANCH" >/dev/null 2>&1 \
  || fail "invalid branch name: $BRANCH"

git -C "$REPO_ROOT" fetch origin --quiet >/dev/null 2>&1 || true

if git -C "$REPO_ROOT" show-ref --verify --quiet "refs/heads/$BRANCH"; then
  git -C "$REPO_ROOT" worktree add "$WORKTREE_PATH" "$BRANCH" >/dev/null 2>&1
elif git -C "$REPO_ROOT" show-ref --verify --quiet "refs/remotes/origin/$BRANCH"; then
  git -C "$REPO_ROOT" worktree add --track -b "$BRANCH" "$WORKTREE_PATH" "origin/$BRANCH" >/dev/null 2>&1
else
  DEFAULT_BRANCH="$(git -C "$REPO_ROOT" symbolic-ref --short refs/remotes/origin/HEAD 2>/dev/null | sed 's@^origin/@@' || true)"
  [ -n "$DEFAULT_BRANCH" ] \
    || fail "cannot resolve origin's default branch (try: git remote set-head origin --auto)"
  BASE_REF="refs/remotes/origin/$DEFAULT_BRANCH"
  git -C "$REPO_ROOT" rev-parse --verify "$BASE_REF^{commit}" >/dev/null 2>&1 \
    || fail "missing $BASE_REF"
  git -C "$REPO_ROOT" worktree add -b "$BRANCH" "$WORKTREE_PATH" "$BASE_REF" >/dev/null 2>&1
fi

TOPLEVEL="$(git -C "$WORKTREE_PATH" rev-parse --show-toplevel 2>/dev/null)"
HEAD_BRANCH="$(git -C "$WORKTREE_PATH" symbolic-ref --quiet --short HEAD 2>/dev/null)"
[ "$TOPLEVEL" = "$WORKTREE_PATH" ] || fail "worktree path mismatch"
[ "$HEAD_BRANCH" = "$BRANCH" ]    || fail "worktree HEAD mismatch"

if [ -n "${CMUX_WORKSPACE_ID:-}" ] && command -v cmux >/dev/null 2>&1 && cmux ping >/dev/null 2>&1; then
  cmux workspace-action --workspace "$CMUX_WORKSPACE_ID" --action rename --title "$BRANCH" >/dev/null 2>&1 || true
fi

copy_clip() {
  local payload="$1"
  if command -v pbcopy >/dev/null 2>&1; then printf '%s' "$payload" | pbcopy 2>/dev/null
  elif command -v wl-copy >/dev/null 2>&1; then printf '%s' "$payload" | wl-copy 2>/dev/null
  elif command -v xclip >/dev/null 2>&1; then printf '%s' "$payload" | xclip -selection clipboard 2>/dev/null
  else return 1
  fi
}

build_prompt() {
  local desc=""
  if [ -n "$LINEAR_DESCRIPTION" ]; then
    desc="$(printf '%s' "$LINEAR_DESCRIPTION" | sed -E 's/!\[[^]]*\]\([^)]*\)//g' | sed -E 's/^[[:space:]]+|[[:space:]]+$//g')"
  fi
  printf 'Work on Linear issue %s:\n\n' "$DISPLAY_ID"
  printf '<issue identifier="%s">\n' "$DISPLAY_ID"
  [ -n "$LINEAR_TITLE" ] && printf '<title>%s</title>\n' "$LINEAR_TITLE"
  [ -n "$LINEAR_URL" ]   && printf '<url>%s</url>\n' "$LINEAR_URL"
  if [ -n "$desc" ]; then
    printf '<description>\n%s\n</description>\n' "$desc"
  fi
  printf '</issue>\n'
}

CD_CMD="cd $WORKTREE_PATH"
copy_clip "$CD_CMD" || true

spin_stop

if [ -n "$LINEAR_TITLE" ] || [ -n "$LINEAR_URL" ] || [ -n "$LINEAR_DESCRIPTION" ]; then
  printf '%sagent prompt:%s\n' "$C_DIM" "$C_RESET"
  build_prompt
elif [ -n "$SLUG" ]; then
  printf '%s — %s\n' "$DISPLAY_ID" "$SLUG"
else
  printf '%s\n' "$DISPLAY_ID"
fi

printf '\n%scopied:%s\n%s%s%s\n' "$C_DIM" "$C_RESET" "$C_BOLD" "$CD_CMD" "$C_RESET"
